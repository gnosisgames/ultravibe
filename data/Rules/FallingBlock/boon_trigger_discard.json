      },
      {
        "path": "",
        "op": "CHANCE_PERCENT",
        "value": {
          "fromContext": "parameters.chancePercent"
        }
      }
    ],
    "outcomes": [
      {
        "type": "CALL_SERVICE",
        "target": "FallingBlock.AddDiscards",
        "value": {
          "amount": {
            "fromContext": "parameters.out_amount"
          }
        }
      }
    ],
    "parameters": {
      "minLinesCleared": 1,
      "chancePercent": 25,
      "out_amount": 1
    }
  }
}
