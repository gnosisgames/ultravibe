window/stretch/aspect="expand"
mouse_cursor/custom_image="res://addons/com.gnosisgames.gnosisengine/assets/Sprites/Cursors/pointer_b.png"

[dotnet]

project/assembly_name="Ultravibe"

[editor_plugins]

enabled=PackedStringArray("res://addons/com.gnosisgames.gnosisengine/plugin.cfg")

[gui]

theme/custom="res://assets/ui/ultravibe_theme.tres"

